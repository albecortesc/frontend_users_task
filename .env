VITE_API_BASE_URL=/api
VITE_API_TOKEN=

# Auth
VITE_AUTH_LOGIN_PATH=/users/login

# Users endpoints
VITE_USERS_CREATE_PATH=/users/register

# Endpoint for updating a user with PUT (without appending /:id)
VITE_USERS_UPDATE_PATH=/users

# Endpoint for changing the current user's password
VITE_CHANGE_PASSWORD_PATH=/users/password

# Endpoint for changing another user's password from admin UI
VITE_ADMIN_CHANGE_USER_PASSWORD_PATH=/users/password/admin

# Endpoint base for deleting a user (the app appends /:id)
VITE_USERS_DELETE_PATH=/users
